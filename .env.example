# Server-only переменные окружения (не доступны в браузере)

# Продакшен: Backend на отдельном сервере (HTTPS)
AUTH_GATEWAY_BASE_URL=https://api.hackplatform.ru
PLATFORM_API_BASE_URL=https://api.hackplatform.ru

# Dev: Backend локально
# AUTH_GATEWAY_BASE_URL=http://localhost:8080
# PLATFORM_API_BASE_URL=http://localhost:8080

# Dev: Backend в Docker на том же хосте
# AUTH_GATEWAY_BASE_URL=http://host.docker.internal:8080
# PLATFORM_API_BASE_URL=http://host.docker.internal:8080

# Centrifugo WebSocket.
# Продакшен (за nginx-прокси с TLS):
NEXT_PUBLIC_CENTRIFUGO_WS_URL=wss://api.hackplatform.ru/connection/websocket
# Локальный Centrifugo:
# NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://127.0.0.1:8000/connection/websocket

# Next.js
NODE_ENV=production

# Secure cookies (обязательно для HTTPS)
FORCE_SECURE_COOKIES=true

# Публичный origin хранилища аватаров (как в avatarUrl от API).
# Продакшен (MinIO за nginx-прокси с TLS):
NEXT_PUBLIC_AVATAR_STORAGE_ORIGIN=https://api.hackplatform.ru
# Если MinIO на отдельном домене:
# NEXT_PUBLIC_AVATAR_STORAGE_ORIGIN=https://storage.hackplatform.ru
# Локальный MinIO:
# NEXT_PUBLIC_AVATAR_STORAGE_ORIGIN=http://localhost:9000
