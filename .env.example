# Server-only переменные окружения (не доступны в браузере)

# Продакшен: Backend на отдельном сервере
AUTH_GATEWAY_BASE_URL=http://api.hackplatform.ru:8080
PLATFORM_API_BASE_URL=http://api.hackplatform.ru:8080

# Dev: Backend локально
# AUTH_GATEWAY_BASE_URL=http://localhost:8080
# PLATFORM_API_BASE_URL=http://localhost:8080

# Dev: Backend в Docker на том же хосте
# AUTH_GATEWAY_BASE_URL=http://host.docker.internal:8080
# PLATFORM_API_BASE_URL=http://host.docker.internal:8080

# Centrifugo WebSocket.
# Без NEXT_PUBLIC — дефолт ws://api.hackplatform.ru:8000/connection/websocket.
# HTTPS:
# NEXT_PUBLIC_CENTRIFUGO_WS_URL=wss://api.hackplatform.ru/connection/websocket
# Локальный Centrifugo:
# NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://127.0.0.1:8000/connection/websocket

# Next.js
NODE_ENV=production

# Secure cookies (только для HTTPS)
# FORCE_SECURE_COOKIES=true
